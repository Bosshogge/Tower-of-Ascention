{
  "AllowedHosts": "*",
  "Api": {
    "Enabled": true,
    "Cors": {},
    "AllowedNetworkTypes": 1,
    "AllowedNonHttpOnlyCookies": [
      "session-expires"
    ],
    "RequestLogLevel": 0,
    "TokenGenerationOptions": {
      "AccessTokenLifetime": 5,
      "Audience": "https://localhost/api",
      "Issuer": "https://localhost",
      "RefreshTokenLifetime": 10080,
      "Secret": "9C544E93602AD30BF2BD2E8C27C1F0065B503770BB64CC3A6715651B053348E9376E5D026BA51CE072BC1FB1CF1025D5D30B6E6DC33B58BD82E62A86699A55A8"
    },
    "KnownProxies": [],
    "StaticFilePaths": [
      {
        "SourcePath": "wwwroot"
      }
    ],
    "JwtBearerOptions": {
      "TokenValidationParameters": {
        "ValidAudience": "https://localhost/api",
        "ValidIssuer": "https://localhost"
      }
    }
  },
  "ConnectionStrings": {
    "Game": "Data Source=resources/gamedata.db",
    "Identity": "Data Source=resources/identity.db",
    "Logging": "Data Source=resources/logging.db",
    "Player": "Data Source=resources/playerdata.db"
  },
  "DetailedErrors": false,
  "Kestrel": {
    "AddServerHeader": false,
    "AllowResponseHeaderCompression": true,
    "DisableStringReuse": false,
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5400"
      },
      "Https": {
        "Certificate": {
          "Path": "self-signed.crt",
          "KeyPath": "self-signed.key"
        },
        "Url": "https://*:5443"
      }
    },
    "Limits": {
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 100
    }
  },
  "Logging": {
    "Common": {
      "MinimumLevel": {
        "Default": "Error",
        "Override": {
          "Intersect": "Warning",
          "Microsoft": "Warning",
          "System": "Warning"
        }
      }
    }
  },
  "UpdateServer": {
    "Enabled": true,
    "AssetRoot": "assets"
  }
}